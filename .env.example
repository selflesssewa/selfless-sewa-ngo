# Local development environment variables.
# Gitignored (.env*.local) — safe to keep secrets here, never committed.

# --- Contentful (your space for now; swap to client's later) ---
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=

# --- JWT signing secret for payment flow ---
JWT_SECRET=

# --- Site URL (used for PhonePe redirect after mandate setup) ---
SITE_URL=https://selflesssewango.com

# --- PhonePe Standard Checkout v2 / Autopay (OAuth) ---
# Obtain from the PhonePe Business dashboard once Autopay is enabled.
PHONEPE_ENV=SANDBOX            # SANDBOX | PRODUCTION
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1
# Webhook auth (set the same username/password in the PhonePe dashboard)
PHONEPE_WEBHOOK_USERNAME=
PHONEPE_WEBHOOK_PASSWORD=

# --- Database (Neon / Vercel Postgres — any Postgres connection string) ---
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# --- Admin (owner-only donor ledger at /admin) ---
ADMIN_KEY=

# --- Cron protection (generate: openssl rand -hex 32) ---
CRON_SECRET=
