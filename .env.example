# Environment variables. Copy to .env.local for local dev (gitignored).
# For production, set these in Vercel → Project → Settings → Environment Variables.
# See docs/DEPLOYMENT.md for production values and docs/TESTING.md for local setup.

# --- PhonePe Standard Checkout v2 (OAuth) — powers BOTH one-time and recurring ---
PHONEPE_ENV=SANDBOX            # SANDBOX (local) | PRODUCTION (live)
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1

# --- Site URL (PhonePe redirect-back target) ---
SITE_URL=http://localhost:3000          # production: https://selflesssewango.com

# --- Database (Neon / any Postgres) ---
DATABASE_URL=                            # pooled connection string (runtime)
DATABASE_URL_UNPOOLED=                   # direct URL — only used by `npm run db:migrate`

# --- Secrets (generate: openssl rand -hex 32) ---
JWT_SECRET=                              # signs the payment/receipt token
CRON_SECRET=                             # guards the cron endpoints (Vercel sends it automatically)
ADMIN_KEY=                               # password for the /admin dashboard

# --- Google Drive archiving (Apps Script Web App under the NGO Google account) ---
GOOGLE_APPS_SCRIPT_URL=
GOOGLE_APPS_SCRIPT_SECRET=

# --- Contentful (site content / CMS) ---
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=

# --- PhonePe webhook Basic-auth (set the same pair in the PhonePe dashboard) ---
# NOTE: the webhook route does not verify these yet — see docs/DEPLOYMENT.md step 4.
PHONEPE_WEBHOOK_USERNAME=
PHONEPE_WEBHOOK_PASSWORD=

# Deprecated (v1 salt-key auth — no longer used, safe to omit):
#   PHONEPE_MERCHANT_ID, PHONEPE_SALT_KEY, PHONEPE_SALT_INDEX
